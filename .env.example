# Скопируйте этот файл в .env и заполните своими значениями.
# Сам .env в репозиторий не коммитится (см. .gitignore).

# Сгенерировать новый SECRET_KEY можно командой:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-random-secret-key

DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Домены фронтенда, которым разрешены кросс-доменные запросы к API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- База данных (если переменные не заданы, используется SQLite) ---
# POSTGRES_DB=orders
# POSTGRES_USER=orders
# POSTGRES_PASSWORD=change-me
# POSTGRES_HOST=db
# POSTGRES_PORT=5432

# --- Почта ---
# Если EMAIL_HOST_USER не задан и DEBUG=True, письма пишутся в консоль.
# Для Gmail используйте app password (НЕ обычный пароль аккаунта):
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
